<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header: Hari Ini -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Jadwal Hari Ini"
            android:textColor="#2D2D2D"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/widget_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buka"
            android:textColor="#D4A853"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1.5dp"
        android:background="#20000000"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Tampilkan jika sedang kosong -->
    <TextView
        android:id="@+id/empty_schedule_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Belum ada jadwal hari ini.\nSaatnya istirahat! 🎉"
        android:textColor="#6B6B6B"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.5"
        android:fontFamily="sans-serif"
        android:visibility="gone"/>

    <!-- Menampilkan ListView jadwal (Kotak per jadwal) -->
    <ListView
        android:id="@+id/schedule_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="12dp"
        android:scrollbars="none" />

</LinearLayout>
