<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jadwal Hari Ini"
        android:textColor="#2D2D2D"
        android:textSize="14sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true" />

    <View
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20000000"
        android:layout_below="@+id/widget_title"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/today_schedule"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tidak ada jadwal hari ini"
        android:textColor="#4A4A4A"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.4"
        android:fontFamily="sans-serif"
        android:layout_below="@+id/widget_divider" />

    <TextView
        android:id="@+id/widget_open_app"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Buka Aplikasi"
        android:textColor="#D4A853"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true" />

</RelativeLayout>
